<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MediaVault.ViewModels"
             x:Class="MediaVault.Controls.MediaCard"
             x:DataType="vm:MediaCardViewModel">

  <Border x:Name="Root"
          CornerRadius="8"
          ClipToBounds="True"
          Background="{DynamicResource CardBg}"
          Cursor="Hand">

    <Panel>

      <!-- ── Static thumbnail ─────────────────────────────────────── -->
      <Image x:Name="ThumbImage"
             Source="{Binding Thumbnail}"
             Stretch="UniformToFill" />

      <!-- ── Loading skeleton ─────────────────────────────────────── -->
      <Border IsVisible="{Binding IsLoadingThumbnail}"
              Background="{DynamicResource CardSkeletonBg}">
        <TextBlock Text="⋯"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextMuted}"
                   FontSize="24" />
      </Border>

      <!-- ── Live video preview frame (memory-render) ─────────────── -->
      <Image x:Name="PreviewImage"
             Stretch="UniformToFill"
             IsVisible="False" />

      <!-- ── Audio placeholder ─────────────────────────────────────── -->
      <Border IsVisible="False" x:Name="AudioBadge"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <Path Data="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"
              Fill="{DynamicResource Accent}"
              Width="48" Height="48"
              Stretch="Uniform" />
      </Border>

      <!-- ── Bottom gradient + metadata ──────────────────────────── -->
      <Border VerticalAlignment="Bottom" Padding="10,6">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Color="Transparent" Offset="0" />
            <GradientStop Color="#CC000000"   Offset="1" />
          </LinearGradientBrush>
        </Border.Background>
        <StackPanel Spacing="2">
          <TextBlock Text="{Binding File.Name}"
                     Foreground="White"
                     FontSize="12"
                     FontWeight="SemiBold"
                     TextTrimming="CharacterEllipsis" />
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{Binding File.FormattedDuration}"
                       Foreground="#CCFFFFFF" FontSize="11" />
            <TextBlock Text="{Binding File.ResolutionText}"
                       Foreground="#88FFFFFF" FontSize="11" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ── Hover play-button overlay ────────────────────────────── -->
      <Border x:Name="HoverOverlay"
              IsVisible="False"
              Background="#2AFFFFFF">
        <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
          <Ellipse Width="52" Height="52"
                   Fill="#80000000" />
          <Path Data="M 8 6 L 24 14 L 8 22 Z"
                Fill="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="4,0,0,0"
                Stretch="Uniform"
                Width="22" Height="22" />
        </Panel>
      </Border>

    </Panel>
  </Border>
</UserControl>
