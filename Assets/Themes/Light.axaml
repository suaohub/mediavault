<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Light -->
  <SolidColorBrush x:Key="AppBg"          Color="#F5F5F8" />
  <SolidColorBrush x:Key="HeaderBg"       Color="#FFFFFF" />
  <SolidColorBrush x:Key="SubbarBg"       Color="#F0F0F4" />
  <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF" />
  <SolidColorBrush x:Key="CardSkeletonBg" Color="#E8E8F0" />
  <SolidColorBrush x:Key="SearchBg"       Color="#EBEBF0" />
  <SolidColorBrush x:Key="BorderColor"    Color="#D8D8E8" />
  <SolidColorBrush x:Key="Accent"         Color="#6366F1" />
  <SolidColorBrush x:Key="AccentHover"    Color="#4F52D9" />
  <SolidColorBrush x:Key="TextPrimary"    Color="#1A1A2E" />
  <SolidColorBrush x:Key="TextMuted"      Color="#888899" />
</ResourceDictionary>
