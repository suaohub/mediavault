<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ── Base button ──────────────────────────────────────────────────── -->
  <Style Selector="Button">
    <Setter Property="CornerRadius"   Value="6" />
    <Setter Property="Padding"        Value="12,7" />
    <Setter Property="FontSize"       Value="13" />
    <Setter Property="Cursor"         Value="Hand" />
    <Setter Property="Background"     Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground"     Value="{DynamicResource TextPrimary}" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>

  <!-- accent button -->
  <Style Selector="Button.accent">
    <Setter Property="Background" Value="{DynamicResource Accent}" />
    <Setter Property="Foreground" Value="White" />
  </Style>
  <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentHover}" />
  </Style>

  <!-- outlined button -->
  <Style Selector="Button.outlined">
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush"     Value="{DynamicResource BorderColor}" />
    <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}" />
  </Style>
  <Style Selector="Button.outlined:pointerover /template/ ContentPresenter">
    <Setter Property="Background"  Value="{DynamicResource SearchBg}" />
  </Style>

  <!-- ghost / icon button -->
  <Style Selector="Button.ghost">
    <Setter Property="Padding"    Value="6" />
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
  </Style>
  <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SearchBg}" />
  </Style>

  <!-- control button (player) -->
  <Style Selector="Button.ctrl">
    <Setter Property="Background"  Value="#22FFFFFF" />
    <Setter Property="Foreground"  Value="White" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding"     Value="12,8" />
  </Style>
  <Style Selector="Button.ctrl:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#40FFFFFF" />
  </Style>

  <!-- ── Chip filter button ────────────────────────────────────────────── -->
  <Style Selector="Button.chip">
    <Setter Property="Background"  Value="Transparent" />
    <Setter Property="Foreground"  Value="{DynamicResource TextMuted}" />
    <Setter Property="Padding"     Value="14,5" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="FontSize"    Value="13" />
  </Style>
  <Style Selector="Button.chip:pointerover /template/ ContentPresenter">
    <Setter Property="Background"  Value="{DynamicResource SearchBg}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>
  <Style Selector="Button.chip.active /template/ ContentPresenter">
    <Setter Property="Background"  Value="{DynamicResource Accent}" />
    <Setter Property="TextElement.Foreground" Value="White" />
  </Style>

  <!-- ── Folder chip (ToggleButton) ────────────────────────────────────── -->
  <Style Selector="ToggleButton.folderChip">
    <Setter Property="Background"  Value="{DynamicResource SearchBg}" />
    <Setter Property="Foreground"  Value="{DynamicResource TextMuted}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding"     Value="12,4" />
    <Setter Property="FontSize"    Value="12" />
  </Style>
  <Style Selector="ToggleButton.folderChip:checked /template/ ContentPresenter">
    <Setter Property="Background"  Value="{DynamicResource Accent}" />
    <Setter Property="TextElement.Foreground" Value="White" />
  </Style>

  <!-- ── TextBox ───────────────────────────────────────────────────────── -->
  <Style Selector="TextBox">
    <Setter Property="SelectionBrush" Value="{DynamicResource Accent}" />
    <Setter Property="CaretBrush"     Value="{DynamicResource Accent}" />
  </Style>
  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <!-- ── ComboBox ──────────────────────────────────────────────────────── -->
  <Style Selector="ComboBox">
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding"      Value="10,6" />
    <Setter Property="FontSize"     Value="13" />
  </Style>

  <!-- ── ScrollBar ─────────────────────────────────────────────────────── -->
  <Style Selector="ScrollBar">
    <Setter Property="Opacity" Value="0.4" />
  </Style>

</Styles>
