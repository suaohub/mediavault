<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Emerald Forest -->
  <SolidColorBrush x:Key="AppBg"          Color="#060E09" />
  <SolidColorBrush x:Key="HeaderBg"       Color="#0A1510" />
  <SolidColorBrush x:Key="SubbarBg"       Color="#08120D" />
  <SolidColorBrush x:Key="CardBg"         Color="#0E1C14" />
  <SolidColorBrush x:Key="CardSkeletonBg" Color="#14261C" />
  <SolidColorBrush x:Key="SearchBg"       Color="#101F17" />
  <SolidColorBrush x:Key="BorderColor"    Color="#1A3024" />
  <SolidColorBrush x:Key="Accent"         Color="#10B981" />
  <SolidColorBrush x:Key="AccentHover"    Color="#34D399" />
  <SolidColorBrush x:Key="TextPrimary"    Color="#D4F0E0" />
  <SolidColorBrush x:Key="TextMuted"      Color="#4A6C56" />
</ResourceDictionary>
